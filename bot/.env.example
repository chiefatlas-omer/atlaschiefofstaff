# ─────────────────────────────────────────────────────────────────────────────
# Atlas Chief of Staff — Bot Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Slack bot OAuth token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...

# Slack app-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-...

# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────

# OpenAI API key — enables semantic search / embeddings (non-fatal if missing)
OPENAI_API_KEY=

# Slack signing secret (used to verify webhook payloads; defaults to 'dev')
SLACK_SIGNING_SECRET=

# ── Zoom Integration ──────────────────────────────────────────────────────────

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# ── User Slack IDs ────────────────────────────────────────────────────────────

OMER_SLACK_USER_ID=U...
MARK_SLACK_USER_ID=U...
EHSAN_SLACK_USER_ID=U...

# ── Channel IDs ───────────────────────────────────────────────────────────────

TEAM_A_CHANNEL_ID=C...
TEAM_B_CHANNEL_ID=C...
FOUNDERHUBHQ_CHANNEL_ID=C...

# ── Database / Server ─────────────────────────────────────────────────────────

# Path to the SQLite database file (default: ./data/chiefofstaff.db)
DATABASE_PATH=./data/chiefofstaff.db

# Timezone for cron jobs and date display (default: America/Chicago)
TZ=America/Chicago

# HTTP port for the web server (default: 3000)
PORT=3000
