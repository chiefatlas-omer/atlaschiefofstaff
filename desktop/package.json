{
  "name": "atlas-chief-of-staff-desktop",
  "version": "0.3.0",
  "description": "AI Chief of Staff desktop app — voice-controlled computer automation",
  "author": "Atlas Growth",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "copy-static": "node -e \"const fs=require('fs');const path=require('path');['index.html','styles.css'].forEach(f=>{const src=path.join('src','renderer',f);const dest=path.join('dist','renderer',f);fs.mkdirSync(path.dirname(dest),{recursive:true});fs.copyFileSync(src,dest)})\"",
    "dev": "tsc && npm run copy-static && electron .",
    "build": "tsc && npm run copy-static",
    "start": "electron .",
    "watch": "tsc --watch",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.atlasgrowth.chief",
    "productName": "Atlas Chief",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": null,
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "publish": {
      "provider": "github",
      "owner": "chiefatlas-omer",
      "repo": "atlaschiefofstaff"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "openai": "^4.85.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "electron": "^33.3.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  }
}
