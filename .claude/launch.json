{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "bot",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/index.ts"],
      "port": 3000
    },
    {
      "name": "web-server",
      "cwd": "web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/server/index.ts"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "web",
      "cwd": "web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5175"],
      "port": 5175
    }
  ]
}
